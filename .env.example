# Copy to .env and adjust. Every value has a sensible default for local Docker,
# so the only thing you typically change is the LLM section.

# --- LLM ---
# "fake"       -> deterministic offline stub, no API key needed (default).
# "openrouter" -> real generation via OpenRouter (requires a key below).
LLM_PROVIDER=fake
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Any OpenRouter model id. Free models end in ":free".
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Infra (override only if not using docker-compose) ---
# DATABASE_URL=postgresql+psycopg2://memory:memory@postgres:5432/memory
# REDIS_URL=redis://redis:6379/0
# S3_ENDPOINT_URL=http://minio:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=memories

# --- Worker reliability ---
# MAX_ATTEMPTS=3
# RETRY_BACKOFF_SECONDS=2
